#!/bin/bash
# magnolia-run — wraps any command and logs it to the project session JSONL (schema v2).
# Usage: magnolia-run <command...>

set -uo pipefail

COMMAND="$*"
START_ISO="$(date -u +%Y-%m-%dT%H:%M:%S.%6NZ)"
START_EPOCH_MS=$(($(date +%s%N) / 1000000))

PROJECT_DIR=""
CURDIR="$(pwd)"
while [ "$CURDIR" != "/" ]; do
    if [ -d "$CURDIR/.magnolia" ]; then
        PROJECT_DIR="$CURDIR"
        break
    fi
    CURDIR="$(dirname "$CURDIR")"
done
if [ -z "$PROJECT_DIR" ]; then
    PROJECT_DIR="$(pwd)"
fi
PROJECT_ID="$(basename "$PROJECT_DIR")"

SESSION_ID="${MAGNOLIA_SESSION_ID:-}"
if [ -z "$SESSION_ID" ] && [ -f "$PROJECT_DIR/.magnolia/.current-session-id" ]; then
    SESSION_ID="$(cat "$PROJECT_DIR/.magnolia/.current-session-id")"
fi
if [ -z "$SESSION_ID" ]; then
    SESSION_ID="$(date -u +%Y-%m-%d_%H%M%S)"
fi

SESSIONS_DIR="$PROJECT_DIR/.magnolia/sessions"
mkdir -p "$SESSIONS_DIR"
SESSION_FILE="$SESSIONS_DIR/${SESSION_ID}.jsonl"

if [ ! -f "$SESSION_FILE" ]; then
    printf '{"event_type":"session_start","timestamp":"%s","session_id":"%s","project_id":"%s","project_dir":"%s","schema_version":2}\n' \
        "$START_ISO" "$SESSION_ID" "$PROJECT_ID" "$PROJECT_DIR" >> "$SESSION_FILE"
fi

escape_json() {
    printf '%s' "$1" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read())[1:-1])'
}
CMD_ESCAPED="$(escape_json "$COMMAND")"

printf '{"event_type":"tool_call","timestamp":"%s","session_id":"%s","project_id":"%s","source":"magnolia-run","tool":"shell","args_summary":"%s"}\n' \
    "$START_ISO" "$SESSION_ID" "$PROJECT_ID" "$CMD_ESCAPED" >> "$SESSION_FILE"

eval "$COMMAND"
EXIT_CODE=$?

END_ISO="$(date -u +%Y-%m-%dT%H:%M:%S.%6NZ)"
END_EPOCH_MS=$(($(date +%s%N) / 1000000))
DURATION_MS=$((END_EPOCH_MS - START_EPOCH_MS))

if [ $EXIT_CODE -eq 0 ]; then
    printf '{"event_type":"tool_success","timestamp":"%s","session_id":"%s","project_id":"%s","source":"magnolia-run","tool":"shell","duration_ms":%d,"result_summary":"exit=0"}\n' \
        "$END_ISO" "$SESSION_ID" "$PROJECT_ID" "$DURATION_MS" >> "$SESSION_FILE"
else
    printf '{"event_type":"tool_error","timestamp":"%s","session_id":"%s","project_id":"%s","source":"magnolia-run","tool":"shell","duration_ms":%d,"error":"exit=%d"}\n' \
        "$END_ISO" "$SESSION_ID" "$PROJECT_ID" "$DURATION_MS" "$EXIT_CODE" >> "$SESSION_FILE"
fi

magnolia-memory assess \
    --project-dir "$PROJECT_DIR" \
    --command "$COMMAND" \
    --exit "$EXIT_CODE" \
    2>/dev/null || true

exit $EXIT_CODE
