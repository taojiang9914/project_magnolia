#!/bin/bash
# magnolia-selfreflex — automatic memory consolidation for Project Magnolia
# Self-reflex: the programmed habit of examining one's own actions to improve.
# Run this via cron to enable automatic self-reflex:
#   0 11 * * * /path/to/softwares/bin/magnolia-selfreflex /path/to/projects/my_project
#
# What it does:
# 1. Compacts session logs (prunes old tool outputs, keeps summaries)
# 2. Distills recent sessions into project-tier staging entries
# 3. Consolidates stale/duplicate project entries
# 4. Syncs any queued HPC events

set -euo pipefail

PROJECT_DIR="${1:-.}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"
MEMORY_DIR="$PROJECT_DIR/.magnolia"

if [ ! -d "$MEMORY_DIR" ]; then
    echo "No .magnolia directory found in $PROJECT_DIR"
    exit 1
fi

TIMESTAMP=$(date -Iseconds)
LOG_FILE="$MEMORY_DIR/selfreflex.log"

# Pick random quotes from the single-source Python module
OPENING="$(python -c 'from compchem_memory.reflections import pick_quote; print(pick_quote("opening"))' 2>/dev/null || echo '吾日三省吾身 — I examine myself three times a day.')"
CLOSING="$(python -c 'from compchem_memory.reflections import pick_quote; print(pick_quote("closing"))' 2>/dev/null || echo '知错能改，善莫大焉 — There is no greater good than the ability to correct one'\''s errors.')"

echo "[$TIMESTAMP] magnolia-selfreflex started for $PROJECT_DIR" >> "$LOG_FILE"
echo "[$TIMESTAMP] $OPENING" >> "$LOG_FILE"

# 1. Compact session logs
echo "[$TIMESTAMP] Compacting session logs..." >> "$LOG_FILE"
magnolia-memory compact-session \
    --project-dir "$PROJECT_DIR" >> "$LOG_FILE" 2>&1 || true

# 2. Distill recent sessions into staging entries
echo "[$TIMESTAMP] Distilling sessions..." >> "$LOG_FILE"
SESSION_FILE=$(ls -t "$MEMORY_DIR/sessions/"*.jsonl 2>/dev/null | head -n 1)
if [ -n "$SESSION_FILE" ]; then
    python -c "
from compchem_memory.extraction import AutomaticMemoryExtractor
from pathlib import Path
import sys

try:
    extractor = AutomaticMemoryExtractor('$PROJECT_DIR')
    saved = extractor.commit(Path('$SESSION_FILE'), '$PROJECT_DIR')
    print(f'Distilled {len(saved)} learnings from $SESSION_FILE')
except Exception as e:
    print(f'Distillation skipped or failed: {e}')
    sys.exit(0)
" >> "$LOG_FILE" 2>&1 || true
else
    echo "No session file found." >> "$LOG_FILE"
fi

# 3. Consolidate project tier (remove duplicates, stale entries)
echo "[$TIMESTAMP] Consolidating project memory..." >> "$LOG_FILE"
python -c "
from compchem_memory.learning.consolidator import consolidate_tier
from compchem_memory.storage import ensure_project_store
import sys

pd = ensure_project_store('$PROJECT_DIR')
try:
    result = consolidate_tier(str(pd), 'project')
    print(result)
except Exception as e:
    print(f'Consolidation skipped or failed: {e}')
    sys.exit(0)
" >> "$LOG_FILE" 2>&1 || true

# 4. Sync any queued HPC events
echo "[$TIMESTAMP] Syncing HPC queue..." >> "$LOG_FILE"
magnolia-memory sync-queue \
    --project-dir "$PROJECT_DIR" \
    --delete-after >> "$LOG_FILE" 2>&1 || true

TIMESTAMP=$(date -Iseconds)
echo "[$TIMESTAMP] $CLOSING" >> "$LOG_FILE"
echo "[$TIMESTAMP] magnolia-selfreflex finished" >> "$LOG_FILE"
