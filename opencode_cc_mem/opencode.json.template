{
  "$schema": "https://opencode.ai/config.json",
  "tools": { "bash": false },
  "logLevel": "INFO",
  "plugin": [
    ".opencode/plugins/magnolia-session-capture.ts",
    ".opencode/plugins/claim-critic.ts"
  ],
  "mcp": {
    "compchem-tools": {
      "type": "local",
      "command": ["@@PYTHON@@", "-m", "compchem_tools.server"],
      "timeout": 660000,
      "enabled": true,
      "environment": {
        "MAGNOLIA_ROOT": "@@MAGNOLIA_ROOT@@",
        "MAGNOLIA_SKILLS_DIR": ".magnolia/skills",
        "MAGNOLIA_PROJECT_DIR": "projects/@@PROJECT@@"
      }
    },
    "compchem-memory": {
      "type": "local",
      "command": ["@@PYTHON@@", "-m", "compchem_memory.server"],
      "timeout": 660000,
      "enabled": true,
      "environment": {
        "MAGNOLIA_ROOT": "@@MAGNOLIA_ROOT@@",
        "MAGNOLIA_SKILLS_DIR": ".magnolia/skills",
        "MAGNOLIA_PROJECT_DIR": "projects/@@PROJECT@@"
      }
    }
  },
  "instructions": [
    "rules/*.md",
    "AGENTS.md",
    "projects/@@PROJECT@@/.magnolia/boot-context.md",
    "projects/@@PROJECT@@/.magnolia/audit-report.md"
  ]
}
