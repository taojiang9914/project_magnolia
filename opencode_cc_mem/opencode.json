{
  "$schema": "https://opencode.ai/config.json",
  "tools": { "bash": false },
  "mcp": {
    "compchem-tools": {
      "type": "local",
      "command": ["python", "-m", "compchem_tools.server"],
      "environment": {
        "MAGNOLIA_SKILLS_DIR": ".magnolia/skills",
        "MAGNOLIA_PROJECT_DIR": "projects/my_project"
      }
    },
    "compchem-memory": {
      "type": "local",
      "command": ["python", "-m", "compchem_memory.server"],
      "environment": {
        "MAGNOLIA_SKILLS_DIR": ".magnolia/skills",
        "MAGNOLIA_PROJECT_DIR": "projects/my_project"
      }
    }
  },
  "instructions": [
    "rules/*.md",
    "AGENTS.md",
    "projects/my_project/.magnolia/boot-context.md",
    "projects/my_project/.magnolia/audit-report.md"
  ]
}
