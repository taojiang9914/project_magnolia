{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "compchem-tools": {
      "type": "local",
      "command": ["python", "-m", "compchem_tools.server"],
      "environment": {
        "MAGNOLIA_SKILLS_DIR": ".magnolia/skills",
        "MAGNOLIA_PROJECT_DIR": "projects/my_project"
      }
    },
    "compchem-memory": {
      "type": "local",
      "command": ["python", "-m", "compchem_memory.server"],
      "environment": {
        "MAGNOLIA_SKILLS_DIR": ".magnolia/skills",
        "MAGNOLIA_PROJECT_DIR": "projects/my_project"
      }
    }
  },
  "instructions": ["rules/*.md", "AGENTS.md"]
}
